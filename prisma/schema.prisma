generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===================================
// PERFIL E AUTH (Clerk gerencia auth)
// ===================================

model Profile {
  id        String   @id // Clerk user ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email     String   @unique
  name      String
  avatarUrl String?
  phone     String?
  role      Role     @default(VENDEDOR)
  segment   String?
  onboarded Boolean  @default(false)

  // Assinatura Stripe
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  plan                 Plan    @default(FREE)
  planExpiresAt        DateTime?

  // Gamificação
  xp    Int @default(0)
  level Int @default(1)

  // Relações
  diagnostics       Diagnostic[]
  virtualCompany    VirtualCompany?
  progress          UserProgress[]
  lessonProgress    UserLessonProgress[]
  objectionSessions ObjectionSession[]
  generatedScripts  GeneratedScript[]
  xpTransactions    XPTransaction[]
  userBadges        UserBadge[]
  userMissions      UserMission[]
  ninetyDayPlans    NinetyDayPlan[]
  managedTeam       Team?           @relation("TeamManager")
  teamMembership    TeamMember?
  sentMessages      Message[]
  assignedConversations Conversation[] @relation("AssignedConversations")
  scheduledMessages ScheduledMessage[]
}

enum Role {
  VENDEDOR
  FUNCIONARIO
  GESTOR
  ADMIN
}

enum Plan {
  FREE
  PRO
  TEAM
}

// ===================================
// MÓDULO 1 — SCANNER EMPRESARIAL
// ===================================

model Diagnostic {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  // Dados da empresa
  companyName String
  segment     String
  teamSize    String

  // Scores por categoria (0-100)
  scoreLeads     Int @default(0)
  scoreProcess   Int @default(0)
  scoreTeam      Int @default(0)
  scoreKpis      Int @default(0)
  scoreTools     Int @default(0)
  scoreValue     Int @default(0)
  scoreRetention Int @default(0)
  scoreMoney     Int @default(0)
  scoreTotal     Int @default(0)

  answers        String // JSON das respostas
  diagnosticType String @default("EMPRESA") // EMPRESA | VENDEDOR
  llm            String @default("claude")

  result DiagnosticResult?
}

model DiagnosticResult {
  id           String     @id @default(cuid())
  diagnosticId String     @unique
  diagnostic   Diagnostic @relation(fields: [diagnosticId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  summary        String
  strengths      String // JSON array
  weaknesses     String // JSON array
  actions        String // JSON array
  priority       String // CRITICO | ATENCAO | BOM | EXCELENTE
  classification String @default("{}") // JSON: { leads: CRITICO|ATENCAO|FORTE, ... }
  insights       String @default("{}") // JSON: { leads: "...", ... }
}

// ===================================
// MÓDULO 2 — SIMULAÇÃO GAMIFICADA
// ===================================

model VirtualCompany {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profileId    String  @unique
  profile      Profile @relation(fields: [profileId], references: [id])
  diagnosticId String?

  name         String
  segment      String
  currentMRR   Float  @default(0)
  currentMonth Int    @default(1)

  rounds SimulationRound[]
}

model SimulationRound {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  companyId String
  company   VirtualCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  month     Int
  mrrBefore Float
  mrrAfter  Float

  decisions   RoundDecision[]
  aiAnalysis  String? // JSON — benchmark + feedback da IA

  unlockedTrailId String?
}

model RoundDecision {
  id      String          @id @default(cuid())
  roundId String
  round   SimulationRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  category String
  decision String
  impact   Float // impacto percentual no MRR
  xpGained Int   @default(0)
}

// ===================================
// MÓDULO 3 — TRILHAS DE APRENDIZADO
// ===================================

model Trail {
  id          String   @id @default(cuid())
  title       String
  description String
  segments    String[] // segmentos de mercado aplicáveis
  funnel      FunnelStage
  coverImage  String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  modules  TrailModule[]
  progress UserProgress[]
}

enum FunnelStage {
  PROSPECCAO
  QUALIFICACAO
  PROPOSTA
  NEGOCIACAO
  FECHAMENTO
  POS_VENDA
}

model TrailModule {
  id          String @id @default(cuid())
  trailId     String
  trail       Trail  @relation(fields: [trailId], references: [id], onDelete: Cascade)

  title       String
  description String
  order       Int    @default(0)

  lessons Lesson[]
}

model Lesson {
  id       String      @id @default(cuid())
  moduleId String
  module   TrailModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  title     String
  type      LessonType @default(TEXT)
  content   String // Markdown ou URL de vídeo
  order     Int        @default(0)
  xpReward  Int        @default(10)
  duration  Int        @default(5) // minutos estimados

  quiz     Quiz?
  progress UserLessonProgress[]
}

enum LessonType {
  TEXT
  VIDEO
  QUIZ
}

model Quiz {
  id       String @id @default(cuid())
  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  questions QuizQuestion[]
}

model QuizQuestion {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  question String
  options  String[] // array de alternativas
  correct  Int      // índice da opção correta
  order    Int      @default(0)
}

model UserProgress {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  trailId   String
  trail     Trail    @relation(fields: [trailId], references: [id])

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  completed   Boolean   @default(false)

  @@unique([profileId, trailId])
}

model UserLessonProgress {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])

  completed   Boolean   @default(false)
  score       Int? // pontuação no quiz (0-100)
  completedAt DateTime?

  @@unique([profileId, lessonId])
}

// ===================================
// MÓDULO 4 — SIMULADOR DE OBJEÇÕES
// ===================================

model ObjectionSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  objection String // tipo de objeção (preço, concorrente, timing...)
  segment   String
  product   String

  messages   ObjectionMessage[]
  completed  Boolean @default(false)
  finalScore Int? // 0-100
  feedback   String? // feedback da IA ao final
  xpGained   Int     @default(0)
}

model ObjectionMessage {
  id        String           @id @default(cuid())
  sessionId String
  session   ObjectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role      String // "user" | "assistant" (IA como cliente)
  content   String
  createdAt DateTime @default(now())
}

// ===================================
// MÓDULO 5 — GERADOR DE SCRIPTS
// ===================================

model GeneratedScript {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  segment      String
  leadRole     String // cargo do lead
  product      String
  painPoint    String

  coldCall      String // roteiro de cold call
  followUpEmail String // e-mail de follow-up
  proposal      String // estrutura de proposta
  linkedinMsg   String // mensagem LinkedIn

  llm String @default("claude")
}

// ===================================
// MÓDULO 6 — PLAYBOOK INTERATIVO
// ===================================

model PlaybookItem {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  title     String
  content   String   // Markdown
  category  FunnelStage
  segments  String[] // segmentos aplicáveis
  tags      String[]
  order     Int      @default(0)
  published Boolean  @default(true)
}

// ===================================
// MÓDULO 7 — GAMIFICAÇÃO
// ===================================

model XPTransaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])

  amount Int
  reason String
  source XPSource
}

enum XPSource {
  LESSON_COMPLETE
  QUIZ_PASS
  OBJECTION_PRACTICE
  SCRIPT_GENERATE
  SIMULATION_ROUND
  MISSION_COMPLETE
  BADGE_UNLOCK
  DAILY_LOGIN
  SCANNER_COMPLETE
  DEAL_WON
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String // emoji ou URL
  condition   String // JSON — condição para desbloquear
  xpBonus     Int    @default(0)
  rarity      String @default("COMMON") // COMMON | RARE | EPIC | LEGENDARY

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())

  @@unique([profileId, badgeId])
}

model Mission {
  id          String      @id @default(cuid())
  title       String
  description String
  xpReward    Int
  type        MissionType @default(WEEKLY)
  condition   String // JSON — { action, count }
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())

  userMissions UserMission[]
}

enum MissionType {
  DAILY
  WEEKLY
  PERMANENT
}

model UserMission {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id])

  progress     Int      @default(0)
  completed    Boolean  @default(false)
  completedAt  DateTime?
  weekStart    DateTime? // para missões semanais
  solutionText String?  // plano gerado pela IA ao concluir o desafio

  @@unique([profileId, missionId, weekStart])
}

model NinetyDayPlan {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  diagnosticId String @unique
  content      String // narrativa do plano de 90 dias gerado pela IA

  actions PlanAction[]
}

model PlanAction {
  id     String        @id @default(cuid())
  planId String
  plan   NinetyDayPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  area        String // leads | process | team | kpis | tools | value | retention | money
  phase       Int       @default(1) // 1 = dias 1-30, 2 = dias 31-60, 3 = dias 61-90
  text        String
  impact      Int       @default(5) // quanto soma no score da área ao ser concluída
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
}

// ===================================
// MÓDULO 8 — PAINEL DO GESTOR
// ===================================

model Team {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  managerId String  @unique
  manager   Profile @relation("TeamManager", fields: [managerId], references: [id])

  name          String
  businessModel String  @default("B2B")  // B2B | B2C
  segment       String  @default("")
  subsegment    String  @default("")
  size          String  @default("1-10")
  invite        String  @unique @default(cuid()) // código de convite

  monthlyTokenLimit Int?

  // Créditos de IA comprados pela equipe — não expiram; são consumidos automaticamente
  // depois que o uso do mês estoura o monthlyTokenLimit (ver lib/token-usage.ts)
  aiCreditsBalance Int     @default(0)
  // Cliente na conta Asaas DA PRÓPRIA PLATAFORMA (ASAAS_PLATFORM_API_KEY) — não confundir
  // com o Asaas de cada agente (AgentConfig.asaasApiKey), que é a conta do cliente pra vender
  asaasCustomerId  String?

  members        TeamMember[]
  departamentos  Departamento[]
  goals          Goal[]
  announcements  Announcement[]
  agentConfigs   AgentConfig[]
  creditoCompras CreditoCompra[]
  tokenUsageLogs TokenUsageLog[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  profileId String   @unique
  profile   Profile  @relation(fields: [profileId], references: [id])
  joinedAt  DateTime @default(now())

  departamentoId String?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id], onDelete: SetNull)

  @@unique([teamId, profileId])
}

// Departamento da equipe (Vendas, Suporte, Financeiro...) — a IA transfere conversas
// para o departamento certo com base na descrição do que cada um atende
model Departamento {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  nome      String
  descricao String @default("") // o que esse departamento atende — a IA usa pra rotear

  membros       TeamMember[]
  conversations Conversation[]

  @@index([teamId])
}

model Goal {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  title     String
  target    Float
  current   Float    @default(0)
  unit      String // "leads", "conversões", "%", etc.
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ===================================
// MÓDULO 9 — FERRAMENTAS PLUG-AND-PLAY
// AGENTE DE ATENDIMENTO IA NO WHATSAPP
// ===================================

model AgentConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sem @unique: uma equipe pode ter vários agentes (cada um seu número de WhatsApp e CRM)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  nome     String   @default("Assistente")
  tom      String   @default("CONSULTIVO") // FORMAL | PROXIMO | CONSULTIVO
  servicos String[] @default([])
  objecoes String[] @default([])
  horario  String   @default("")

  // Setor desse agente (taxonomia de lib/segments.ts) — usado pra personalizar o system prompt
  segmento    String @default("")
  subsegmento String @default("")

  descricaoEmpresa String @default("") // história, diferenciais, público-alvo
  precos           String @default("") // valores, formas de pagamento, parcelamento, garantias
  enderecoContato  String @default("") // endereço, site, redes sociais, outros canais

  systemPrompt String?
  active       Boolean @default(false)

  uazapiInstance String?
  uazapiToken    String?

  followupEnabled       Boolean @default(true)
  followupDelaysMinutes Json    @default("[1440]") // minutos de espera por tentativa, ex: [1440, 720] = 24h, depois +12h. O número de tentativas é o tamanho do array.

  schedulingEnabled        Boolean @default(false)
  slotDurationMinutes      Int     @default(30)
  availability             Json    @default("[]") // [{ dayOfWeek: 0-6, start: "09:00", end: "18:00" }]
  appointmentReminderHours Int     @default(24) // quantas horas antes do compromisso enviar a confirmação
  requisitosAgendamento    String  @default("") // informações que o agente deve coletar antes de confirmar o horário
  restricoesAgendamento        String  @default("") // o que o agente NÃO deve fazer no agendamento
  atendimentoEspecialEnabled   Boolean @default(false) // permite oferecer horários fora do comercial
  atendimentoEspecialDescricao String  @default("") // condições do atendimento especial
  askProfessionalEnabled       Boolean @default(true) // com vários profissionais: true = agente pergunta com quem; false = atribui a qualquer um livre
  agendaAccessToken            String? @unique // link da agenda geral da empresa (/agenda/[token], PWA)

  // Como conversas novas são distribuídas entre os atendentes da equipe
  leadDistributionMode LeadDistributionMode @default(MANUAL)
  lastAssignedToId     String? // último atendente que recebeu um lead no rodízio/IA — marca a posição da fila

  // Quando ativo, mensagens manuais de atendentes saem no WhatsApp assinadas com o nome de quem mandou
  signatureEnabled Boolean @default(false)
  emojiEnabled     Boolean @default(false) // permite que o agente de IA use emojis nas respostas

  // Catálogo/pedidos via WhatsApp com pagamento Pix/cartão (Asaas) — cada equipe usa a própria conta
  commerceEnabled  Boolean @default(false)
  catalogOnly      Boolean @default(false) // true = só catálogo/pedidos, sem gerar cobrança online
  asaasApiKey      String? // colada pelo gestor, nunca exibida de volta na UI
  asaasSandbox     Boolean @default(true)
  asaasWebhookToken String? // gerado ao ativar; valida o webhook de confirmação de pagamento

  cobrancaEnabled Boolean @default(false) // agente dedicado a cobrança de dívidas/boletos

  // Prospecção ativa via Google Maps + WhatsApp
  prospeccaoEnabled          Boolean @default(false)
  prospeccaoSegmento         String  @default("") // ex: "dentistas"
  prospeccaoRegiao           String  @default("") // ex: "São Paulo SP"
  prospeccaoMensagemInicial  String  @default("") // template da 1ª mensagem ao prospect
  prospeccaoFollowupDias     Json    @default("[3,7,14]") // dias entre follow-ups

  // Parcelamento no cartão — o acréscimo de juros é calculado por nós (não pela conta Asaas)
  // e embutido no valor total enviado, pra não depender de configuração externa
  installmentsEnabled     Boolean @default(false)
  maxInstallments         Int     @default(1)
  interestFreeInstallments Int    @default(1) // até quantas parcelas não tem acréscimo
  installmentInterestRate Float   @default(0) // % de acréscimo por parcela além das sem juros

  // O agente de IA move leads pelas etapas do pipeline conforme a conversa evolui
  pipelineAutoAvancar Boolean @default(false)

  // Agente de ligação via Twilio + ElevenLabs
  phoneEnabled         Boolean @default(false)
  twilioAccountSid     String?
  twilioAuthToken      String?
  twilioPhoneNumber    String? // número Twilio de origem, ex: +5511...
  elevenlabsApiKey       String?
  elevenlabsVoiceId      String? // ID da voz no ElevenLabs
  phoneCallPrompt        String  @default("") // instruções extras para ligações
  whatsappVoiceEnabled   Boolean @default(false) // enviar também como áudio de voz no WhatsApp

  // Resposta automática a comentários do Instagram via DM
  igCommentAutoDm    Boolean @default(false)
  igCommentDmMessage String? // fallback quando nenhum fluxo bate — null = IA responde

  // Agente de gestão de carteira: pós-venda e recompra automáticos (via cron /api/cron/carteira)
  carteiraEnabled    Boolean @default(false)
  // Agente de Pós-venda (independente da carteira): mensagem pós-compra + pesquisa de satisfação
  posVendaEnabled    Boolean @default(false)
  posVendaDelayHours Int     @default(24)    // horas depois do pagamento
  posVendaMensagem   String  @default("")    // template fixo ({nome} = cliente); vazio = IA gera
  posVendaPesquisaEnabled Boolean @default(true) // pede nota de 0 a 5 na mensagem de pós-venda
  posVendaReviewLink      String  @default("")   // link de avaliação (Google) enviado quando a nota é alta
  posVendaFeedbacks       PosVendaFeedback[]
  // Agente de Recompra (independente): reativação de quem não compra há X dias
  recompraEnabled    Boolean @default(false)
  recompraDias       Int     @default(30)
  carteiraInstrucoes String  @default("")    // orientações pra IA (ofertas, tom, cupons)
  carteiraInativoDias Int    @default(60)    // dias sem compra para nível INATIVO (15/30/60/90/120)

  // Identidade visual do catálogo público (/loja) — logo base64 como as fotos de produto
  storeLogoBase64   String? @db.Text
  storeLogoMimeType String?
  storeSlug         String? @unique // URL amigável do catálogo (/loja/nome-da-loja), gerada do nome da empresa

  // Integração com o sistema do cliente: pedidos (criado/atualizado/pago) são enviados
  // por POST para essa URL, assinados com HMAC-SHA256 quando o secret está definido
  orderWebhookUrl    String?
  orderWebhookSecret String?

  // Opções de entrega do comércio
  deliveryEnabled   Boolean @default(false) // oferece entrega
  pickupEnabled     Boolean @default(true)  // oferece retirada no local
  deliveryFee       Float   @default(0)     // taxa padrão — usada quando não há zonas cadastradas
  deliveryFreeAbove Float?                  // frete grátis a partir desse subtotal (null = nunca)
  deliveryArea      String  @default("")    // área atendida, prazos, observações
  deliveryZones     DeliveryZone[]          // zonas com taxa própria (bairro/região)

  conversations        Conversation[]
  phoneCalls           PhoneCall[]
  pipelines            Pipeline[]
  leadStatuses         LeadStatus[]
  appointments         Appointment[]
  professionals        Professional[]
  services             Service[]
  quickReplies         QuickReply[]
  products             Product[]
  orders               Order[]
  cobrancas            Cobranca[]
  prospects            Prospect[]
  instagramConnection  InstagramConnection?
  igCommentFlows       InstagramCommentFlow[]
  igFunnels            InstagramFunnel[]
  storeBanners         StoreBanner[]
  carteiraTouches      CarteiraTouch[]
  automacoes           Automacao[]
  campanhas            Campanha[]

  @@index([teamId])
}

// Avaliação de satisfação coletada pelo agente de pós-venda
model PosVendaFeedback {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  contactNumber String
  contactName   String  @default("")
  rating        Int     // 0 a 5
  comment       String  @default("")

  @@index([agentConfigId, createdAt])
}

// Campanha de disparo em massa via WhatsApp — processada pelo cron /api/cron/campanhas
// com intervalo aleatório entre envios (anti-bloqueio)
model Campanha {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  nome     String
  mensagem String // mensagem base ({nome} = primeiro nome do contato)
  modo     String @default("NORMAL") // NORMAL | IA_VARIACAO (IA reescreve por destinatário)
  instrucoesIA String @default("")   // orientações extras pra variação (tom, o que preservar)

  status String @default("ENVIANDO") // ENVIANDO | PAUSADA | CONCLUIDA | CANCELADA

  intervaloMinSeg Int @default(45)
  intervaloMaxSeg Int @default(120)
  nextSendAt      DateTime?
  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  destinatarios CampanhaDestinatario[]

  @@index([agentConfigId])
  @@index([status, nextSendAt])
}

model CampanhaDestinatario {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  campanhaId String
  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)

  contactNumber String
  contactName   String  @default("")
  status        String  @default("PENDENTE") // PENDENTE | ENVIADO | ERRO
  mensagemEnviada String?
  sentAt        DateTime?

  @@index([campanhaId, status])
}

// Registro de cada toque automático da gestão de carteira — evita duplicar envios
model CarteiraTouch {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  contactNumber String
  type          String  // "POS_VENDA" | "RECOMPRA"
  orderId       String? // pós-venda: pedido que originou o toque

  @@index([agentConfigId, contactNumber, type])
  @@index([agentConfigId, orderId])
}

// Zona de entrega com taxa própria (ex: "Centro" R$ 5, "Zona Norte" R$ 12)
model DeliveryZone {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name  String
  fee   Float  @default(0)
  order Int    @default(0)

  @@index([agentConfigId])
}

// Banner do carrossel de destaque no topo do catálogo público (/loja)
model StoreBanner {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  imagemBase64   String  @db.Text
  imagemMimeType String
  order          Int     @default(0)
  active         Boolean @default(true)

  @@index([agentConfigId])
}

enum LeadDistributionMode {
  MANUAL              // ninguém é atribuído automaticamente
  PRIMEIRO_A_ASSUMIR  // quem mandar a 1ª mensagem manual na conversa fica responsável
  RODIZIO             // toda conversa nova já nasce atribuída, alternando entre atendentes
  IA_QUALIFICACAO     // a IA avalia a conversa e atribui (rodízio) quando o lead parece qualificado
}

// Se a empresa não cadastrar nenhum profissional, o agendamento usa a disponibilidade
// e duração padrão do AgentConfig (modo "agenda única"). Ao cadastrar profissionais,
// cada um passa a ter sua própria disponibilidade e os agendamentos exigem escolha de profissional.
model Professional {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name         String
  phone        String  @default("") // WhatsApp do profissional — notificado a cada agendamento
  accessToken  String? @unique      // token do link da agenda PWA do profissional (/agenda/[token])
  availability Json    @default("[]") // [{ dayOfWeek: 0-6, start: "09:00", end: "18:00" }]
  active       Boolean @default(true)

  appointments         Appointment[]
  pendingInConversations Conversation[]
}

// Se a empresa não cadastrar nenhum serviço, o agendamento usa slotDurationMinutes do
// AgentConfig. Ao cadastrar serviços, cada um define sua própria duração.
model Service {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name            String
  durationMinutes Int
  active          Boolean @default(true)

  appointments           Appointment[]
  pendingInConversations Conversation[]
}

// ─── Agente de Prospecção ────────────────────────────────────────────────────

enum ProspectStatus {
  NOVO            // scraped, ainda não abordado
  ABORDADO        // primeira mensagem enviada, aguardando resposta
  RESPONDEU       // prospect mandou mensagem, IA qualificando
  QUALIFICADO     // lead bom, encaminhado para atendente humano
  REUNIAO_AGENDADA
  DESCARTADO      // sem perfil ou pediu para parar
  ENCERRADO       // follow-ups esgotados sem resposta
}

model Prospect {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  nome           String
  empresa        String @default("")
  telefone       String
  segmento       String @default("")
  regiao         String @default("")
  sourceUrl      String @default("") // URL da ficha no Google Maps
  status         ProspectStatus @default(NOVO)
  notas          String @default("")  // anotações da qualificação pela IA

  abordagemCount  Int      @default(0) // total de mensagens proativas enviadas
  lastAbordagemAt DateTime?

  @@unique([agentConfigId, telefone]) // evita duplicar o mesmo número no mesmo agente
}

// ─── Agente de Cobrança ──────────────────────────────────────────────────────

enum CobrancaStatus {
  PENDENTE       // registrada, ainda não enviou boleto
  BOLETO_GERADO  // boleto gerado e enviado ao devedor
  PAGO           // confirmação de pagamento recebida
  VENCIDA        // prazo expirou e não foi pago
  CANCELADA
}

enum RecorrenciaCobranca {
  UNICA
  SEMANAL
  QUINZENAL
  MENSAL
  ANUAL
}

model Cobranca {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  nomeDevedor   String
  contactNumber String   // WhatsApp do devedor, só números
  cpfCnpj       String?  // CPF ou CNPJ do devedor (exigido pelo Asaas para gerar boleto)
  valor         Float
  descricao     String   @default("")
  vencimento    DateTime
  status        CobrancaStatus      @default(PENDENTE)
  recorrencia   RecorrenciaCobranca @default(UNICA)

  asaasCustomerId String?
  asaasPaymentId  String?
  boletoUrl       String?  // bankSlipUrl retornado pelo Asaas

  paidAt         DateTime?
  reminderCount  Int      @default(0) // quantos lembretes de follow-up já foram enviados
  lastReminderAt DateTime?
}

// ─── Catálogo do agente de comércio ──────────────────────────────────────────
// Catálogo do agente de comércio — o agente consulta isso antes de informar preço/estoque,
// nunca inventa produto ou valor fora dessa lista.
model Product {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name              String
  description       String  @default("")
  category          String  @default("") // texto livre; "" = sem categoria (aparece por último no catálogo)
  price             Float
  precoPromocional  Float?  // null = sem promoção ativa; quando definido, sobrepõe o preço normal
  stock             Int?    // null = não controla estoque
  active            Boolean @default(true)

  // Foto guardada como base64 direto no banco (sem prefixo "data:...;base64,") — o projeto
  // não tem storage de blob hoje, e o envio pelo WhatsApp (sendMediaAsTeam) já pede base64 puro.
  imagemBase64   String? @db.Text
  imagemMimeType String?

  orderItems OrderItem[]
}

enum OrderStatus {
  ABERTO // carrinho em montagem, ainda sem cobrança gerada
  AGUARDANDO_PAGAMENTO
  PAGO
  EM_PREPARO
  ENVIADO
  ENTREGUE
  CANCELADO
}

model Order {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  agentConfigId  String
  agentConfig    AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  contactName   String
  contactNumber String
  status        OrderStatus @default(ABERTO)
  total         Float       @default(0) // subtotal dos itens (sem taxa de entrega)

  deliveryType    String? // "ENTREGA" | "RETIRADA" — null = ainda não definido
  deliveryFee     Float   @default(0)
  deliveryAddress String  @default("")
  deliveryZone    String  @default("") // nome da zona escolhida, quando a loja usa zonas

  asaasPaymentId  String?
  asaasPixPayload String? // código Pix copia-e-cola
  asaasInvoiceUrl String? // link de checkout hospedado (usado pra pagamento por cartão)
  asaasInstallmentId String? // id do plano de parcelas no Asaas, quando a cobrança é parcelada
  paidAt          DateTime?

  items OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  name      String // snapshot do nome no momento do pedido
  unitPrice Float  // snapshot do preço no momento do pedido
  quantity  Int
}

// Textos prontos que qualquer atendente pode inserir rápido no chat (ex: saudações,
// respostas padrão). Compartilhadas por toda a equipe do número.
model QuickReply {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  title   String // nome curto pra identificar na lista, ex: "Saudação"
  content String

  automacoes Automacao[]
}

// Automação determinística do pipeline (sem IA): quando a mensagem rápida vinculada
// é enviada pelo atendente, o lead move automaticamente para a etapa configurada.
model Automacao {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  nome   String
  active Boolean @default(true)

  trigger String @default("QUICK_REPLY") // extensível: futuros gatilhos (pedido pago, agendamento...)

  quickReplyId String
  quickReply   QuickReply @relation(fields: [quickReplyId], references: [id], onDelete: Cascade)

  targetStageId String
  targetStage   PipelineStage @relation(fields: [targetStageId], references: [id], onDelete: Cascade)

  @@index([agentConfigId])
}

model Appointment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  contactName   String?
  contactNumber String

  scheduledAt     DateTime
  durationMinutes Int      @default(30)
  notes           String   @default("")
  status          AppointmentStatus @default(CONFIRMADO)

  reminderSentAt DateTime? // quando o lembrete de confirmação foi enviado (evita reenvio)
}

enum AppointmentStatus {
  CONFIRMADO
  CANCELADO
  CONCLUIDO
}

// Uma empresa pode ter vários pipelines (ex: Vendas, Suporte). Cada conversa fica em uma
// etapa por vez, e a etapa pertence a um único pipeline — então o pipeline "atual" da
// conversa é sempre o do stage em que ela está.
model Pipeline {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name  String
  order Int    @default(0)

  // Agente responsável pelo funil inteiro: instruções aplicadas a leads em qualquer
  // etapa deste pipeline (as instruções da etapa refinam por cima)
  agenteInstrucoes String @default("")

  stages PipelineStage[]
}

model PipelineStage {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  name  String
  color String @default("#3b82f6")
  order Int    @default(0)

  // Agente responsável pela etapa: instruções que moldam o comportamento da IA
  // enquanto o lead estiver nesta etapa do funil (prioridade sobre o prompt geral)
  agenteInstrucoes String @default("")

  opportunities Opportunity[]
  automacoes    Automacao[]
}

model LeadStatus {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())

  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name  String
  color String @default("#6b7280")
  order Int    @default(0)

  conversations Conversation[]
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  contactNumber  String
  contactName    String?
  status         ConversationStatus @default(ATIVO)
  humanTakeover  Boolean            @default(false) // true = atendente humano assumiu, agente para de responder

  leadStatusId String?
  leadStatus   LeadStatus? @relation(fields: [leadStatusId], references: [id], onDelete: SetNull)

  // Nível manual da carteira ("A"|"B"|"C"|"INATIVO"|"PERDIDO") — null = calculado automaticamente.
  // Usado p.ex. quando o cliente informa que passou a comprar de outro fornecedor (PERDIDO).
  nivelCarteira String?

  // Departamento responsável pela conversa (setado pela IA na transferência ou manualmente)
  departamentoId String?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id], onDelete: SetNull)

  // Encerramento: motivo escolhido pelo atendente + quando — base do relatório de motivos
  motivoEncerramento String?
  encerradaEm        DateTime?

  // Atendente responsável por essa conversa — null = ainda não atribuída (qualquer atendente
  // pode ver e assumir). Quem atribui/quando depende do leadDistributionMode do AgentConfig.
  assignedToId String?
  assignedTo   Profile? @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)

  followupCount  Int       @default(0)
  lastFollowupAt DateTime?

  // Marcado quando alguém da equipe abre a conversa — usado pro filtro "não lidas".
  // É global (não por usuário): se alguém já leu, conta como lida pra todo mundo.
  lastReadAt DateTime?

  // Memoriza o último serviço/profissional que a IA resolveu nessa conversa, pra usar como
  // fallback em agendar_horario caso o modelo não repita o parâmetro na chamada de confirmação.
  pendingProfessionalId String?
  pendingProfessional   Professional? @relation(fields: [pendingProfessionalId], references: [id], onDelete: SetNull)
  pendingServiceId      String?
  pendingService        Service?      @relation(fields: [pendingServiceId], references: [id], onDelete: SetNull)

  // Cacheia o customer já criado no Asaas pra esse contato, evita recriar a cada pedido
  asaasCustomerId String?

  messages          Message[]
  appointments      Appointment[]
  opportunities     Opportunity[]
  scheduledMessages ScheduledMessage[]
  orders            Order[]
  phoneCalls        PhoneCall[]

  @@unique([agentConfigId, contactNumber])
}

// Uma negociação dentro de uma conversa — um mesmo cliente pode ter várias (ex: comprou,
// depois volta pra negociar outra coisa). Cada uma tem seu próprio valor, etapa e status de ganho.
model Opportunity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  stageId        String?
  stage          PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  stageEnteredAt DateTime       @default(now()) // atualizado sempre que stageId muda, pra calcular "dias parado nessa etapa"

  title     String? // nome opcional pra diferenciar quando há mais de uma, ex: "Plano anual"
  dealValue Float
  wonAt     DateTime? // quando foi marcada como ganha (null = ainda em negociação)
}

// Mensagem de texto programada pra ser enviada automaticamente numa data/hora futura —
// o cron de followup verifica e dispara quando chega a hora.
model ScheduledMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   Profile @relation(fields: [createdById], references: [id], onDelete: Cascade)

  content      String
  scheduledFor DateTime
  sentAt       DateTime? // null = ainda não enviada
}

enum ConversationStatus {
  ATIVO
  AGUARDANDO
  FINALIZADO
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String // user | assistant | human
  content String

  mediaUrl  String? // url pública (já descriptografada via UazAPI) da mídia, se houver
  mediaType String? // image | video | audio | document

  senderId String?  // qual atendente mandou (role "human"), pra CRM multiusuário
  sender   Profile? @relation(fields: [senderId], references: [id], onDelete: SetNull)
}

// ─── Controle de consumo de tokens de IA ─────────────────────────────────────

model TokenUsageLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  provider     String   // "openai" | "anthropic"
  model        String   // "gpt-4o-mini" | "claude-sonnet-4-6"
  feature      String   // "whatsapp_agent" | "followup" | "plano" | "missao" | "script" | "objecao" | "scanner" | "simulacao"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)

  @@index([teamId, createdAt])
}

// Compra de créditos extras de IA (top-up), pagamento único via Asaas (conta da plataforma)
model CreditoCompra {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  packId         String // id do pacote em lib/credits.ts, ex: "popular"
  tokens         Int
  valorCentavos  Int
  status         String  @default("PENDENTE") // PENDENTE | PAGO
  formaPagamento String  // PIX | CARTAO
  cpfCnpj        String  @default("")

  asaasPaymentId  String? @unique
  asaasInvoiceUrl String? // link hospedado do Asaas (usado no pagamento por cartão)
  asaasPixPayload String? // código Pix copia-e-cola

  @@index([teamId, createdAt])
}

// ─── Agente de Ligação (Twilio + ElevenLabs) ─────────────────────────────────

enum PhoneCallStatus {
  EM_ANDAMENTO
  CONCLUIDA
  PERDIDA
  FALHADA
}

model PhoneCall {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  direction     String          // "INBOUND" | "OUTBOUND"
  contactNumber String
  contactName   String          @default("")
  status        PhoneCallStatus @default(EM_ANDAMENTO)
  twilioCallSid String?         @unique
  durationSecs  Int?

  // Vincula ao lead existente no CRM
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  turns PhoneCallTurn[]

  @@index([agentConfigId, createdAt])
}

model PhoneCallTurn {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  callId    String
  call      PhoneCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  role      String   // "user" | "assistant"
  content   String   // transcript ou resposta IA
  audioData String?  @db.Text // base64 do áudio ElevenLabs (assistant turns)

  @@index([callId])
}

// ─── Instagram DM ─────────────────────────────────────────────────────────────

model InstagramConnection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentConfigId String      @unique
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  pageId                     String
  pageAccessToken            String
  instagramBusinessAccountId String   @unique
  instagramUsername          String   @default("")
  tokenExpiresAt             DateTime?
  webhookSubscribed          Boolean  @default(false)
}

// ─── Fluxos condicionais de comentários → DM ─────────────────────────────────

model InstagramCommentFlow {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name         String   // label amigável, ex: "Promoção Verão"
  keywords     String[] @default([]) // vazio = aceita qualquer comentário (catch-all)
  replyMessage String   @default("") // mensagem direta (usado quando funnelId é null)
  order        Int      @default(0)
  active       Boolean  @default(true)

  // Quando definido, dispara o funil em vez de enviar replyMessage
  funnelId String?
  funnel   InstagramFunnel? @relation(fields: [funnelId], references: [id], onDelete: SetNull)

  @@index([agentConfigId, order])
}

// ─── Funis de automação estilo Manychat ──────────────────────────────────────

model InstagramFunnel {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)

  name   String
  active Boolean @default(true)

  // Gatilho por DM direto (independente de comentário)
  dmTriggerEnabled  Boolean  @default(false)
  dmTriggerKeywords String[] @default([]) // vazio = qualquer DM; preenchido = só se o texto contiver a palavra

  blocks     InstagramFunnelBlock[]
  executions InstagramFunnelExecution[]
  triggers   InstagramCommentFlow[]

  @@index([agentConfigId])
}

model InstagramFunnelBlock {
  id       String          @id @default(cuid())
  funnelId String
  funnel   InstagramFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  type  FunnelBlockType
  order Int             @default(0)

  // MESSAGE: content = texto enviado no DM
  // DELAY:   delayMinutes = tempo de espera
  // CONDITION: content = texto da pergunta; branches = JSON [{keywords:string[], label:string, funnelId:string|null}]
  content      String?
  delayMinutes Int?
  branches     Json?   // [{keywords: string[], label: string, funnelId: string | null}]

  @@index([funnelId, order])
}

enum FunnelBlockType {
  MESSAGE    // envia DM e avança imediatamente
  DELAY      // aguarda X minutos antes do próximo bloco
  CONDITION  // envia pergunta, aguarda resposta e ramifica por palavra-chave
}

model InstagramFunnelExecution {
  id            String           @id @default(cuid())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  funnelId      String
  funnel        InstagramFunnel  @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  agentConfigId String
  contactIgsid  String           // IGSID do contato no Instagram
  igBusinessAccountId String
  pageAccessToken     String     // token da conexão no momento da execução
  blockIndex    Int              @default(0)
  status        FunnelExecStatus @default(RUNNING)
  resumeAt      DateTime?        // preenchido quando WAITING_DELAY

  @@index([agentConfigId, contactIgsid, status])
  @@index([status, resumeAt])
}

enum FunnelExecStatus {
  RUNNING
  WAITING_DELAY
  WAITING_INPUT
  COMPLETED
}

// Estado anti-CSRF para o fluxo OAuth do Instagram — expira em 5 minutos
model OAuthState {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  state         String   @unique
  agentConfigId String
  userId        String
  expiresAt     DateTime
  used          Boolean  @default(false)
}
